# Copy to .env (gitignored, chmod 600). Never commit the real file.

# Short prefix baked into every token (e.g. acme_management_<random>)
DEPLOY_PREFIX=brain

COMPANY_DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Mode — ./brain setup sets this. Servers: 'external' (attach to an existing
# Traefik — Hostinger ships one) or 'bundled' (deploy ours). Personal brains
# on your own machine: 'local' — MCP binds to 127.0.0.1 only (port via
# BRAIN_LOCAL_PORT, console via CONSOLE_LOCAL_PORT; defaults 8000 / 3300).
TRAEFIK_MODE=bundled
TRAEFIK_NETWORK=brain-proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# Host paths (bind mounts — trivially backupable and human-inspectable)
VAULT_DIR=/srv/company-2nd-brain
AUDIT_DIR=/srv/company-2nd-brain-audit
CLIENTS_DIR=/srv/company-2nd-brain-clients   # dynamic agent registry (hashes only)

# sha256 hex hashes of agent tokens — written by scripts/generate-secrets.sh
# (one line per agent as you add them; setup/add-agent manage this for you).
# Plaintext tokens are printed ONCE at generation and live only in agent configs.
MCP_TOKEN_HASH_ADMIN=CHANGE_ME

# Web console at <CONSOLE_SUBDOMAIN>.<COMPANY_DOMAIN> — enable via ./brain console.
# Login needs a console/admin token; see docs/SECURITY.md before exposing.
CONSOLE_ENABLED=false
CONSOLE_SUBDOMAIN=2ndbrain

# Backup (deploy key with write access to a PRIVATE repo; not a personal PAT)
BACKUP_REMOTE=git@github.com:YOUR_ORG/YOUR_CLIENT-vault-backup.git
BACKUP_SSH_KEY=/srv/backup-key/id_ed25519
BACKUP_INTERVAL_SECONDS=900
